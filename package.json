{
  "name": "@prompty-tools/mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol (MCP) server for the prompty.tools platform - search, fetch, create, and version prompts from your AI client.",
  "keywords": [
    "prompty",
    "prompty-tools",
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "claude",
    "ai",
    "prompts",
    "llm"
  ],
  "author": "prompty.tools <info@prompty.tools>",
  "license": "MIT",
  "homepage": "https://mcp.prompty.tools",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Equites-Digital/prompty-tools-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Equites-Digital/prompty-tools-mcp/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "prompty-tools-mcp": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist coverage docs/tools",
    "docs:build": "npm run build && node scripts/build-docs.mjs",
    "docs:serve": "npm run docs:build && npx --yes http-server docs -p 4173 -c-1",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:build": "tsc --noEmit -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "prepare": "husky",
    "prepublishOnly": "npm run lint && npm run typecheck:build && npm run test:coverage && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prompty-tools/core": "^0.4.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.1.7",
    "rimraf": "^6.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.0"
  }
}
